{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "concurrently -k -n web,collab 'pnpm dev:web' 'pnpm dev:collab'",
    "dev:web": "next dev",
    "dev:collab": "node --env-file-if-exists=.env.local --watch --import tsx server/collaboration.ts",
    "build": "next build",
    "start": "next start",
    "start:web": "next start -H 0.0.0.0 -p 3000",
    "start:proxy": "caddy run --config Caddyfile --adapter caddyfile",
    "start:collab": "node --env-file-if-exists=.env.local --import tsx server/collaboration.ts",
    "start:railway": "concurrently -k -n proxy,web,collab 'pnpm start:proxy' 'pnpm start:web' 'pnpm start:collab'",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "verify": "pnpm test && pnpm lint && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@hocuspocus/extension-database": "^4.4.0",
    "@hocuspocus/provider": "^4.4.0",
    "@hocuspocus/provider-react": "^4.4.0",
    "@hocuspocus/server": "^4.4.0",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-collaboration": "^3.28.0",
    "@tiptap/extension-collaboration-caret": "^3.28.0",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-youtube": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "concurrently": "^10.0.3",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
