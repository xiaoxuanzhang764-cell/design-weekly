DATABASE_PATH=./data/design-weekly.sqlite
MEDIA_ROOT=./storage/uploads
NEXT_PUBLIC_COLLAB_URL=ws://127.0.0.1:1234
COLLABORATION_PORT=1234
COLLAB_INTERNAL_TOKEN=replace-with-a-cryptographically-random-64-character-hex-value
COLLAB_INTERNAL_URL=http://127.0.0.1:1234/internal/restore
APP_TIMEZONE=Asia/Shanghai

# Railway production variables (add these in Railway; do not uncomment locally):
# DATABASE_PATH=/data/design-weekly.sqlite
# MEDIA_ROOT=/data/uploads
# COLLABORATION_PORT=1234
# COLLAB_INTERNAL_URL=http://127.0.0.1:1234/internal/restore
# COLLAB_INTERNAL_TOKEN=<64-character-random-hex>
# APP_TIMEZONE=Asia/Shanghai
# Leave NEXT_PUBLIC_COLLAB_URL unset for same-origin /collaboration routing.
